{
  "name": "delaunay_dev_vite",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "vite:dev": "vite --mode development",
    "docker": "node scripts/start-docker.mjs",
    "docker:up": "node scripts/start-docker.mjs",
    "vite:docker": "vite --mode docker",
    "build": "npm run clean && npm run build:vite && run-s php inc imagemin svgsprite file wpassets",
    "build:vite": "vite build --mode production",
    "build:fast": "npm run clean && npm run build:vite && run-s php inc svgsprite file wpassets",
    "watch": "run-p -c watch:*",
    "watch:inc": "onchange '_src/_inc/**/*' -e '**/*.DS_Store' -- node scripts/copy-changed.mjs --src _src/_inc --dest _public/assets/inc {{changed}}",
    "watch:php": "run-p watch:html watch:page",
    "watch:html": "onchange '_src/html/**/*' -e '**/*.DS_Store' -- node scripts/copy-changed.mjs --src _src/html --dest _public {{changed}}",
    "watch:page": "onchange '_src/_inc/page/**/*' -e '**/*.DS_Store' -- node scripts/copy-changed.mjs --src _src/_inc --dest _public/assets/inc {{changed}}",
    "watch:svg": "onchange '_src/icon/**/*' -e '**/*.DS_Store' -- run-s svgsprite",
    "watch:image": "onchange '_src/image/**/*' -e '**/*.DS_Store' -- node scripts/sharp.mjs --watch {{changed}}",
    "watch:file": "onchange '_src/files/**/*' -e '**/*.DS_Store' -- node scripts/copy-changed.mjs --src _src/files --dest _public/assets/files {{changed}}",
    "watch:wpassets": "onchange '_public/assets/**/*' -e '**/*.DS_Store' -- npm run wpassets",
    "imagemin": "node ./scripts/sharp.mjs",
    "svgsprite": "svg-sprite -C spriteConfig.json _src/icon/*svg",
    "wpassets": "node -e \"require('fs-extra').copySync('./_public/assets', './_wp/themes/assets')\"",
    "php": "node -e \"require('fs-extra').copySync('./_src/html', './_public')\"",
    "file": "node -e \"require('fs-extra').copySync('./_src/files', './_public/assets/files')\"",
    "inc": "node -e \"require('fs-extra').copySync('./_src/_inc', './_public/assets/inc')\"",
    "clean": "rimraf _public/assets/{css/*,js/*,image/*}",
    "server": "php -S 0.0.0.0:8080 -t _public",
    "dev": "node scripts/start-servers.mjs",
    "generate": "node scripts/generate-pages.mjs",
    "postinstall": "npm run generate && npm run build"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.4",
    "autoprefixer": "^10.4.17",
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "fs-extra": "^11.2.0",
    "glob": "^10.3.10",
    "imagemin-svgo": "^10.0.1",
    "npm-run-all": "^4.1.5",
    "onchange": "^7.1.0",
    "postcss": "^8.4.35",
    "postcss-sort-media-queries": "^5.2.0",
    "rimraf": "^5.0.5",
    "sass": "^1.53.0",
    "sharp": "^0.33.2",
    "svg-sprite": "^2.0.2",
    "svgo": "^3.2.0",
    "vite": "^5.0.8",
    "vite-plugin-live-reload": "^3.0.3"
  },
  "dependencies": {
    "@splidejs/splide": "^4.1.4",
    "@splidejs/splide-extension-auto-scroll": "^0.5.3",
    "axios": "^1.7.7",
    "lenis": "^1.3.21"
  },
  "browserslist": [
    "last 2 versions",
    "> 5%",
    "not dead"
  ]
}
